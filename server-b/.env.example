# Server B 配置 (139.224.110.155)

# DeepSeek API 配置（必填）
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-reasoner

# Server A 代理配置（新加坡部署，用于转发外网请求）
# 本地开发时使用 127.0.0.1:8000
# 部署时使用内网地址
SERVER_A_HOST=127.0.0.1
SERVER_A_PORT=8000
SERVER_A_BASE_URL=
SERVER_A_API_TOKEN=

# 端口代理模式（可选）：A 开启 PROXY_PORT 时，设为 true 并填写 A 的代理端口，B 通过 HTTP_PROXY 走 A，yfinance 在 B、外网经 A
# USE_HTTP_PROXY=false
# SERVER_A_PROXY_PORT=8080

# 代理请求超时和重试配置
PROXY_TIMEOUT=30
PROXY_RETRY=3

# CORS 配置 - 允许的来源，多个用逗号分隔
# 本地开发时用 * 即可
# 部署时可以限制为 Server A 的 IP
# CORS_ORIGINS=http://8.219.73.160,http://localhost:3000

# 其他配置（可选）
# LOG_PATH=logs/requests.log
# DEBUG_LOG_PATH=logs/debug.log
# FEEDBACK_DIR=feedback
