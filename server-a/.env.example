# Server A 代理服务器 + 数据 API（价格、财报）

# 服务器 B 的地址（Nginx 将部分请求转发到此）
SERVER_B_HOST=服务器B的IP或域名
SERVER_B_PORT=8001

# API 鉴权（可选，防止外网滥用）
API_TOKEN=

# 允许代理的域名白名单（默认 yfinance 相关）
ALLOWED_DOMAINS=query1.finance.yahoo.com,query2.finance.yahoo.com,finance.yahoo.com,s.yimg.com,image.yahoo.com

# 端口代理（可选）：B 可设 USE_HTTP_PROXY + SERVER_A_PROXY_PORT 经本机出网
# PROXY_PORT=8080
# PROXY_HOST=0.0.0.0

# Redis 缓存配置
REDIS_ENABLED=false
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_PRICE_TTL=3600
REDIS_COMPANY_TTL=604800

# SQLite 缓存路径
PRICE_CACHE_DB_PATH=backend/price_cache.db

# 代理超时
PROXY_EXTERN_TIMEOUT=30

# AkShare 复权参数（可选）
AKSHARE_ADJUST=

# CORS 跨域配置
CORS_ORIGINS=*
